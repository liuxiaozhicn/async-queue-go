{
  "queues": {
    "order": {
      "enabled": true,
      "channel": "queue:order",
      "pop_timeout": 1,
      "handle_timeout": 180,
      "shutdown_timeout": 240,
      "processes": 2,
      "concurrent": 10,
      "max_attempts": 3,
      "message_ttl": 86400,
      "retry_seconds": [5, 10, 30],
      "auto_restart": true,
      "max_messages": 10
    }
  }
}
