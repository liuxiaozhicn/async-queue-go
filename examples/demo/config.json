{
  "queues": {
    "order": {
      "channel": "queue:order",
      "timeout_seconds": 1,
      "handle_timeout": 600,
      "retry_seconds": [5, 10, 30],
      "max_attempts": 3,
      "processes": 2,
      "concurrent": 10,
      "max_messages": 10,
      "shutdown_timeout": 660,
      "enabled": true,
      "auto_restart": true
    }
  }
}
